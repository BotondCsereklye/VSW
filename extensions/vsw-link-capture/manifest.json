{
  "manifest_version": 3,
  "name": "VSW Link Capture",
  "description": "Send clicked links or the current tab target to local VSW for defensive follow-up scans.",
  "version": "0.3.2",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:5173/*",
        "http://localhost:5173/*"
      ],
      "js": [
        "extension-settings-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://127.0.0.1/*",
        "https://localhost/*"
      ],
      "js": [
        "runtime-fallback.js",
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "VSW Link Capture",
    "default_popup": "popup.html"
  }
}
