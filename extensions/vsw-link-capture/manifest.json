{
  "manifest_version": 3,
  "name": "VSW Link Capture",
  "description": "Send clicked links or the current tab target to local VSW for defensive follow-up scans.",
  "version": "0.1.0",
  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "VSW Link Capture",
    "default_popup": "popup.html"
  }
}
