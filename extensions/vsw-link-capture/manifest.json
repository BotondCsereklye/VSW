{
  "manifest_version": 3,
  "name": "VSW Link Capture",
  "description": "Send clicked links or the current tab target to local VSW for defensive follow-up scans.",
  "version": "0.4.0",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:5173/*",
        "http://localhost:5173/*"
      ],
      "js": [
        "extension-settings-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://127.0.0.1/*",
        "https://localhost/*"
      ],
      "js": [
        "runtime-fallback.js",
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/vsw-icon-16.png",
    "32": "icons/vsw-icon-32.png",
    "48": "icons/vsw-icon-48.png",
    "128": "icons/vsw-icon-128.png"
  },
  "action": {
    "default_title": "VSW Link Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/vsw-icon-16.png",
      "32": "icons/vsw-icon-32.png",
      "48": "icons/vsw-icon-48.png",
      "128": "icons/vsw-icon-128.png"
    }
  }
}
